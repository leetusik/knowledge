# knowledge-web environment (P12.S2). Copy to `.env.local` and fill in.
#
# Both keys are SERVER-ONLY — neither is NEXT_PUBLIC_, and both are read through
# `src/lib/env.ts`, which is `import "server-only"`. They must never be exposed to
# the browser: the whole point of the BFF (D-P12-2) is that only the Next.js server
# talks to knowledge-api, and the session key never leaves it.

# Base URL of the knowledge API the Next.js server calls server-to-server.
# Local dev: http://127.0.0.1:8766 (the dev-compose api port).
KB_API_BASE_URL=http://127.0.0.1:8766

# Secret the AES-256-GCM session key is derived from (sha256 of this value) to
# seal knowledge's bearer token into the httpOnly cookie. Use a long random string,
# e.g. `openssl rand -base64 32`. Rotating it invalidates every live session
# (all users are forced to sign in again).
SESSION_SECRET=
