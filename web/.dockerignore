# Lean the build context sent to the Docker daemon — only what `next build` needs.
# `pnpm install --frozen-lockfile` rebuilds node_modules and `next build` regenerates
# .next inside the image, so shipping the host copies just bloats the context.
node_modules
.next
out

# The read-only design-round record (canvas mirror + round outputs) — never built.
design

# Tests + local/editor/VCS noise `next build` never reads.
tests
.git
.gitignore
.env
.env*.local
.DS_Store
*.tsbuildinfo
npm-debug.log*
pnpm-debug.log*
