{
  "version": 1,
  "seed_project": "getting-started",
  "placeholders": {
    "KB_SITE_NAME": "Human-readable site title (mkdocs site_name).",
    "KB_SITE_URL": "Published site URL with trailing slash (mkdocs site_url).",
    "KB_COPYRIGHT": "Footer copyright / attribution line (mkdocs copyright).",
    "KB_TZ": "IANA timezone for the API container, e.g. Asia/Seoul (compose TZ).",
    "KB_VIEWER_PORT": "Host port for the local MkDocs viewer (default 8765).",
    "KB_API_PORT": "Host port for the document API (default 8766).",
    "KB_DATE": "Date stamp (YYYY-MM-DD) for the seed welcome explainer.",
    "KB_DATABASE_URL": "Async SQLAlchemy URL for the accounts plane (compose DATABASE_URL). Empty = accounts dormant, single-tenant (the scaffold default); the operator render supplies the full postgresql+psycopg://... value."
  },
  "files": {
    "identical": [
      "server/__init__.py",
      "server/config.py",
      "server/db.py",
      "server/documents.py",
      "server/embeddings.py",
      "server/gitops.py",
      "server/main.py",
      "server/reindex.py",
      "server/search.py",
      "server/accounts/__init__.py",
      "server/accounts/auth.py",
      "server/accounts/repository.py",
      "server/accounts/security.py",
      "server/accounts/service.py",
      "server/accounts/types.py",
      "server/api_auth.py",
      "server/app_api.py",
      "server/auth_api.py",
      "server/dashboard_api.py",
      "server/documents_api.py",
      "server/graph_api.py",
      "server/persistence/__init__.py",
      "server/persistence/base.py",
      "server/persistence/engine.py",
      "server/persistence/models.py",
      "server/seed.py",
      "server/usage/__init__.py",
      "server/usage/metering.py",
      "server/usage/repository.py",
      "server/usage/service.py",
      "server/usage/types.py",
      "server/usage_api.py",
      "scripts/graph_hook.py",
      "scripts/site_smoke.py",
      "tests/conftest.py",
      "tests/test_accounts_provisioning.py",
      "tests/test_api_push.py",
      "tests/test_api_read.py",
      "tests/test_api_write.py",
      "tests/test_dashboard_api.py",
      "tests/test_documents.py",
      "tests/test_documents_api.py",
      "tests/test_embeddings.py",
      "tests/test_graph_api.py",
      "tests/test_html_documents.py",
      "tests/test_reindex.py",
      "docs/graph.md",
      "docs/tags.md",
      "docs/assets/favicon.svg",
      "docs/assets/logo.svg",
      "docs/stylesheets/extra.css",
      "docs/javascripts/graph.js",
      "Dockerfile",
      "pyproject.toml",
      "uv.lock",
      ".dockerignore"
    ],
    "parameterized": [
      "mkdocs.yml",
      "compose.yml"
    ],
    "template_only": [
      "docs/index.md",
      "docs/getting-started/index.md",
      "docs/getting-started/{{KB_DATE}}-how-your-knowledge-base-works.md",
      "Makefile",
      ".gitignore"
    ]
  },
  "shipped_dirs": [
    "server",
    "tests",
    "docs/assets",
    "docs/stylesheets",
    "docs/javascripts"
  ]
}
